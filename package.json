{
  "name": "techlead",
  "version": "0.2.0",
  "description": "CLI-first autonomous multi-agent engineering loop for any codebase",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.29.3",
  "bin": {
    "techlead": "./dist/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check": "node ./dist/cli.js --help",
    "check:all": "pnpm run typecheck && pnpm run build && pnpm run check && pnpm run validate:distribution",
    "validate:distribution": "node ./scripts/validate-distribution.mjs",
    "prepublishOnly": "pnpm run build",
    "postinstall": "pnpm approve-builds esbuild",
    "fmt": "biome format --write .",
    "fmt:check": "biome format .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "ci": "biome ci . && pnpm run typecheck && pnpm run build",
    "prepare": "husky"
  },
  "dependencies": {
    "cac": "^7.0.0",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@changesets/cli": "^2.29.8",
    "@types/node": "^25.3.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "agent",
    "autonomous",
    "llm",
    "multi-agent",
    "workflow",
    "automation"
  ],
  "files": [
    "dist/",
    "templates/",
    "scripts/",
    "README.md",
    "LICENSE"
  ],
  "lint-staged": {
    "*.{js,ts,mjs,cjs,json,md}": [
      "biome format --write"
    ],
    "*.{js,ts,mjs,cjs}": [
      "biome lint"
    ]
  },
  "changeset": {
    "access": "public",
    "baseBranch": "main"
  }
}
